<!-- res/drawable/spinner_border.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#00000000" /> <!-- Background color -->
    <stroke
        android:width="2dp"
        android:color="#000000" /> <!-- Border color -->
    <corners android:radius="16dp" /> <!-- Optional: rounded corners -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>
